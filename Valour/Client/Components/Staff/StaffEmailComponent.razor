@inject StaffService StaffService
@inject IStringLocalizer<StaffEmailComponent> Localizer

<LanguageTrackProvider OnInitializeEvent="provider => provider.RegisterComponent(this)" />
<div class="verify-user-container">
    <h5>@Localizer["Send Mass Email"]</h5>
    <p class="verify-user-help">
        @Localizer["Send an email to all verified users. This action cannot be undone."]
    </p>

    <div style="display: flex; flex-direction: column; gap: 0.5em;">
        <input class="v-input"
               placeholder="@Localizer["Subject"]"
               @bind-value="_subject" />
        <textarea class="v-input"
                  placeholder="@Localizer["HTML body content"]"
                  rows="8"
                  @bind="_htmlBody"></textarea>
        <button class="v-btn primary"
                disabled="@_isSubmitting"
                @onclick="OnSendClicked">
            @Localizer["Send to All Verified Users"]
        </button>
    </div>

    @if (_result is not null)
    {
        <span class="@(_result.Success ? "text-info" : "text-danger")" style="margin-top: 0.5em; display: block;">@_result.Message</span>
    }
</div>

@code {
    private string _subject = string.Empty;
    private string _htmlBody = string.Empty;
    private ITaskResult _result;
    private bool _isSubmitting;

    private void OnSendClicked()
    {
        if (string.IsNullOrWhiteSpace(_subject) || string.IsNullOrWhiteSpace(_htmlBody))
        {
            _result = TaskResult.FromFailure(Localizer["Subject and body are required."]);
            return;
        }

        var cData = new ConfirmModalComponent.ModalParams(
            Localizer["Mass Email"],
            Localizer["Are you sure you want to send this email to ALL verified users?"],
            Localizer["Yes, send it"],
            Localizer["Cancel"],
            async () => await SendEmailAsync(),
            () => Task.CompletedTask
        );

        ModalRoot.Instance.OpenModal<ConfirmModalComponent>(cData);
    }

    private async Task SendEmailAsync()
    {
        _isSubmitting = true;
        StateHasChanged();

        var toastData = new ProgressToastData<TaskResult>()
        {
            Title = Localizer["Mass Email"],
            Message = Localizer["Sending emails..."],
            SuccessMessage = Localizer["Mass email sent!"],
            ProgressTask = StaffService.SendMassEmailAsync(_subject.Trim(), _htmlBody.Trim())
        };

        _result = await ToastContainer.Instance.WaitToastWithTaskResult(toastData);

        if (_result.Success)
        {
            _subject = string.Empty;
            _htmlBody = string.Empty;
        }

        _isSubmitting = false;
        StateHasChanged();
    }
}
