@implements IDisposable
@inject ValourClient Client
@inject IStringLocalizer<EditFriendsComponent> Localizer
@inject IStringLocalizer<ValourApp> CommonLocalizer

<LanguageTrackProvider OnInitializeEvent="provider => provider.RegisterComponent(this)" />
<div class="settings-page">

    @* ===== Add Friend ===== *@
    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-person-plus"></i>
            @Localizer["Add Friend"]
        </h3>

        <div class="form-group">
            <div class="input-group add-friend-row">
                <input class="v-input" @bind-value="@_name" placeholder="username#tag" @onkeydown="OnKeyDown" />
                <VButton Variant="primary" OnClick="@OnClickSubmit">@Localizer["Add"]</VButton>
            </div>
            <p class="helper-text">@Localizer[_nameSpan]</p>
            <ResultLabel Result="@_friendBoxResult" ParentComponentLocalizer="Localizer"/>
        </div>
    </div>

    @* ===== Incoming Requests ===== *@
    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-person-down"></i>
            @Localizer["Added You"]
        </h3>

        @if (!Client.FriendService.IncomingRequests.Any())
        {
            <p class="helper-text">@Localizer["No incoming friend requests."]</p>
        }
        else
        {
            <div class="request-list">
                @foreach (var addedMe in Client.FriendService.IncomingRequests)
                {
                    <div class="request-row" @key="@addedMe.Id">
                        <UserInfoComponent User="@addedMe" ShowBadges="false" />

                        <div class="action-row" role="group" aria-label="@Localizer["Friend Accept or Deny"]">
                            <VButton Variant="primary" Size="sm" OnClick="@(async () => await OnAcceptRequest(addedMe))">@CommonLocalizer["Accept"]</VButton>
                            <VButton Variant="secondary" Size="sm" OnClick="@(async () => await OnDeclineRequest(addedMe))">@CommonLocalizer["Decline"]</VButton>
                        </div>
                    </div>
                }
            </div>
        }
        <ResultLabel Result="@_addedYouResult" ParentComponentLocalizer="Localizer"/>
    </div>

    @* ===== Outgoing Requests ===== *@
    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-person-up"></i>
            @Localizer["You Added"]
        </h3>

        @if (!Client.FriendService.OutgoingRequests.Any())
        {
            <p class="helper-text">@Localizer["No outgoing friend requests."]</p>
        }
        else
        {
            <div class="request-list">
                @foreach (var added in Client.FriendService.OutgoingRequests)
                {
                    <div class="request-row" @key="@added.Id">
                        <UserInfoComponent User="@added" ShowBadges="false" />

                        <div class="action-row" role="group" aria-label="@Localizer["Cancel Request"]">
                            <VButton Variant="secondary" Size="sm" OnClick="@(async () => await OnCancelRequest(added))">@CommonLocalizer["Cancel"]</VButton>
                        </div>
                    </div>
                }
            </div>
        }
        <ResultLabel Result="@_addedResult" />
    </div>

</div>

@code {
    // Input fields
    private string _name;

    // Spans
    private string _nameSpan = "Enter as username#tag (e.g. Victor#0000)";

    private ITaskResult _addedYouResult = null;
    private ITaskResult _addedResult = null;
    private ITaskResult _friendBoxResult = null;

    protected override void OnInitialized()
    {
        Client.FriendService.FriendsChanged += FriendEventHandler;
    }
    
    void IDisposable.Dispose()
    {
        Client.FriendService.FriendsChanged -= FriendEventHandler;
    }

    private Task FriendEventHandler(FriendEventData eventData)
    {
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await OnClickSubmit();
    }

    private async Task OnClickSubmit()
    {
        // Require a name
        if (string.IsNullOrWhiteSpace(_name))
        {
            _friendBoxResult = new TaskResult(false, Localizer["Please input a username."]);
            return;
        }

        // Validate format: must contain # with text on both sides
        var hashIndex = _name.IndexOf('#');
        if (hashIndex <= 0 || hashIndex >= _name.Length - 1)
        {
            _friendBoxResult = new TaskResult(false, Localizer["Invalid format. Use username#tag (e.g. SpikeViper#a1b2)."]);
            return;
        }

        var response = await Client.FriendService.AddFriendAsync(_name);
        _friendBoxResult = response;
    }

    private async Task OnAcceptRequest(User user)
    {
        var result = await Client.FriendService.AddFriendAsync(user.NameAndTag);
        _addedYouResult = result;

        StateHasChanged();
    }

    private async Task OnDeclineRequest(User user)
    {
        var result = await Client.FriendService.DeclineFriendAsync(user.NameAndTag);
        _addedYouResult = result;

        StateHasChanged();
    }

    private async Task OnCancelRequest(User user)
    {
        var result = await Client.FriendService.CancelFriendAsync(user.NameAndTag);
        _addedResult = result;

        StateHasChanged();
    }
}
