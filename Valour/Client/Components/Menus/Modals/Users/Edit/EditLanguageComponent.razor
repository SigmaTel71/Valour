@using System.Globalization
@using System.Resources
@using Blazor.WebAssembly.DynamicCulture.LocalizationManager
@using Resources.Components.Menus.Modals.Users.Edit

@inject ILocalizationService LocalizationService
@inject LocalizationLocalStorageManager LocLSM
@inject IAppStorage LocalStorage
@inject ValourClient Client

<LanguageTrackProvider OnInitializeEvent="provider => provider.RegisterComponent(this)" />

<div class="perm-list-section">
    <h5>@EditLanguageContent.Select_language</h5>
    <select class="form-control lang-select" @onchange="OnLanguageChange">
        @foreach(string cultureCode in SupportedCultures.Get())
        {
        var ci = @CultureInfo.GetCultureInfo(cultureCode);
        <option class="form-select" selected="@(_currentCultureCode == cultureCode)" value="@cultureCode">@ci.TextInfo.ToTitleCase(ci.NativeName)</option>
        }   
    </select>
</div>

<hr />

<div class="perm-list-section">
    <div class="perm-list-item">
        <div class="perm-list-name">
            @EditLanguageContent.SyncLangBetweenDevices
        </div>
        <div type="button" style="float:right">
            <label class="switch">
                <input type="checkbox" @onclick="SwitchSyncLangBetweenDevices" checked="@_syncBetweenDevices">
                <span class="slider round"></span>
            </label>
        </div>
        <div class="perm-list-desc mt-1">
            @EditLanguageContent.SyncLangBetweenDevicesDesc
        </div>
        <ResultLabel Result="@_syncBetweenDevicesResult" />
    </div>
    <div class="perm-list-item">
        <div class="perm-list-name">
            @EditLanguageContent.Time_format
        </div>
        <div class="perm-list-desc mt-1"></div>
        @foreach (TimeSettings.TimeFormatPreference timePref in Enum.GetValues<TimeSettings.TimeFormatPreference>())
        {
        <label class="switch switch-radio">
                <input type="radio" value="@timePref" name="timeFormatPref" />@_resmonELC.GetString(timePref.ToString())
            <span class="radio round"></span>
        </label>
        <br/>
        }
    </div>
</div>

@code {
    private bool _syncBetweenDevices = true;
    private string _currentCultureCode = SupportedCultures.Default;
    private ResourceManager _resmonELC = new ResourceManager(typeof(Resources.Components.Menus.Modals.Users.Edit.EditLanguageContent));

    private ITaskResult _syncBetweenDevicesResult;

    protected override async Task OnInitializedAsync()
    {
        _currentCultureCode = await LocLSM.GetBlazorCultureAsync();
        await LoadPreferences();
    }

    private async Task LoadPreferences()
    {
        var response = await Client.PrimaryNode.GetJsonAsync<UserPreferences>("api/users/me/preferences");
        if (response.Success && response.Data is not null)
        {
            _syncBetweenDevices = response.Data.SyncLanguageBetweenDevices;
            _currentCultureCode = response.Data.Language;
        }
    }

    private async Task OnLanguageChange(ChangeEventArgs e)
    {
        async Task ApplyCulture(string cultureCode)
        {
            _currentCultureCode = cultureCode;
            
            CultureInfo newCulture = new CultureInfo(_currentCultureCode);
            CultureInfo.DefaultThreadCurrentCulture = newCulture;
            CultureInfo.DefaultThreadCurrentUICulture = newCulture;
            await LocLSM.SetBlazorCultureAsync(newCulture.Name);
            LocalizationService.InvokeLanguageChanged(newCulture);
        }

        string chosenCultureCode = e.Value?.ToString();

        if (_syncBetweenDevices)
        {
            var result = await Client.PrimaryNode.PostAsyncWithResponse<UserPreferences>($"api/users/me/preferences/language/{chosenCultureCode}");

            if (result.Success)
            {
                await ApplyCulture(result.Data.Language);
                return;
            }
        }
        else
        {   
            if (SupportedCultures.Get().Any(culture => culture.Equals(chosenCultureCode, StringComparison.InvariantCultureIgnoreCase)))
                await ApplyCulture(chosenCultureCode);
        }
    }

    private async Task SwitchSyncLangBetweenDevices()
    {
        var rollbackValue = _syncBetweenDevices;

        var result = await Client.PrimaryNode.PostAsyncWithResponse<UserPreferences>(
            $"api/users/me/preferences/syncLanguageBetweenClients/{_syncBetweenDevices}"
        );

        if (result.Success && result.Data is not null)
        {
            _syncBetweenDevices = result.Data.SyncLanguageBetweenDevices;
            _syncBetweenDevicesResult = new TaskResult(true, "Language synchronization preferences updated.");
        }
        else
        {
            _syncBetweenDevices = rollbackValue;
            _syncBetweenDevicesResult = new TaskResult(false, result.Message);
        }
    }
}