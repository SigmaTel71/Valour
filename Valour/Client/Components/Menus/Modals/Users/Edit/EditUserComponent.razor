@using Valour.Client.Components.Windows.ModTools
@using Valour.Client.Components.Staff
@inherits Modal<EditUserComponent.ModalParams>
@inject IStringLocalizer<EditUserComponent> Localizer
@inject NavigationManager NavManager
@inject ValourClient Client
@inject IAppStorage LocalStorage

<LanguageTrackProvider OnInitializeEvent="provider => provider.RegisterComponent(this)" />
@if (@Data.User is null)
{
    <div class="background">
        <h5>@Localizer["Loading user..."]</h5>
    </div>
    return;
}

<MainMenuComponent DefaultCategory="@Data.StartCategory" DefaultItem="@Data.StartItem" MenuCategories="@_categories"  />

@code {

    [CascadingParameter]
    public BrowserUtils DomWindow { get; set; }

    private RenderFragment ProfileContent => @<EditProfileComponent />;
    private RenderFragment FriendsContent => @<EditFriendsComponent />;
    private RenderFragment SafetyContent => @<EditSafetyComponent />;
    private RenderFragment AttachmentsContent => @<EditAttachmentsComponent />;
    private RenderFragment ThemesContent => @<EditThemeComponent />;
    private RenderFragment SubscriptionsContent => @<EditSubscriptionsComponent />;
    private RenderFragment ReferralsContent => @<EditReferralsComponent />;
    private RenderFragment NotificationsContent => @<EditUserNotificationsComponent />;
    private RenderFragment DevicePreferencesContent => @<EditDevicePreferencesComponent />;
    private RenderFragment LanguageContent =>@<EditLanguageComponent />;
    private RenderFragment SecurityContent => @<EditSessionsComponent />;
    private RenderFragment LogOutContent => @<div></div>;
    private RenderFragment OAuthContent => @<EditOAuthComponent />;
    private RenderFragment BotsContent => @<BotManagementComponent />;
    private RenderFragment StaffToolsContent =>
        @<TabContainerComponent Titles="@_staffTabs" MaxHeight="100%" ContentStyle="background-color: var(--main-1); padding: 1em">
            <TabOne>
                <StaffUserQueryTable />
            </TabOne>
            <TabTwo>
                <ReportsQueryTable />
            </TabTwo>
            <TabThree>
                <StaffVerifyUserComponent />
            </TabThree>
            <TabFour>
                <StaffEmailComponent />
            </TabFour>
        </TabContainerComponent>
    ;

    private readonly string[] _staffTabs = new[] { "StaffToolsTabMembers", "StaffToolsTabReports", "StaffToolsTabVerify", "StaffToolsTabMassEmail" };

    private List<MainMenu.MenuCategory> _categories;

    private List<MainMenu.MenuCategory> BuildCategories() =>
        new List<MainMenu.MenuCategory>()
        {
            new MainMenu.MenuCategory()
            {
                Name = Localizer["General Settings"],
                Icon = "gear-fill",
                Items = new List<MainMenu.MenuItem>()
                {
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Profile"],
                        Icon = "person-fill",
                        Description = Localizer["Edit your profile, avatar, and appearance"],
                        Content = ProfileContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Friends"],
                        Icon = "person-heart",
                        Description = Localizer["Manage your friends and requests"],
                        Content = FriendsContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Safety"],
                        Icon = "shield-fill-check",
                        Description = Localizer["Manage blocks and DM privacy"],
                        Content = SafetyContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Attachments"],
                        Icon = "paperclip",
                        Description = Localizer["View, search, and delete uploaded attachments"],
                        Content = AttachmentsContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Themes"],
                        Icon = "palette-fill",
                        Description = Localizer["Create and install custom themes"],
                        Content = ThemesContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Subscriptions"],
                        Icon = "rocket-takeoff-fill",
                        Description = Localizer["Upgrade your experience!"],
                        Content = SubscriptionsContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Referrals"],
                        Icon = "envelope-paper-heart-fill",
                        Description = Localizer["Invite friends and earn rewards"],
                        Content = ReferralsContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Notifications"],
                        Icon = "bell-fill",
                        Description = Localizer["Manage notification preferences and sound"],
                        Content = NotificationsContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Device Preferences"],
                        Icon = "phone-fill",
                        Description = Localizer["Manage device preferences"],
                        Content = DevicePreferencesContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Language & Time"],
                        Icon = "globe",
                        Description = Localizer["Manage user interface language and time preferences"],
                        Content = LanguageContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Security"],
                        Icon = "shield-lock-fill",
                        Description = Localizer["MFA, password, and active sessions"],
                        Content = SecurityContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Log Out"],
                        Icon = "x-octagon-fill",
                        Color = "var(--color-danger)",
                        Content = LogOutContent,
                        OnClick = LogOut
                    }
                }
            },
            new MainMenu.MenuCategory()
            {
                Name = Localizer["Developer"],
                Icon = "code-slash",
                Items = new List<MainMenu.MenuItem>()
                {
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Bots"],
                        Icon = "robot",
                        Description = Localizer["Create and manage bot accounts"],
                        Content = BotsContent
                    },
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["OAuth Apps"],
                        Icon = "key-fill",
                        Description = Localizer["Manage your OAuth applications and API access"],
                        Content = OAuthContent
                    }
                }
            },
        };

    protected override void OnInitialized()
    {
        // Backward compatibility for callers using previous menu item names.
        if (string.Equals(Data.StartItem, "Permissions", StringComparison.OrdinalIgnoreCase)
            || string.Equals(Data.StartItem, "Notification Options", StringComparison.OrdinalIgnoreCase))
        {
            Data.StartItem = "Notifications";
        }

        // "Info" was merged into "Profile"
        if (string.Equals(Data.StartItem, "Info", StringComparison.OrdinalIgnoreCase))
        {
            Data.StartItem = "Profile";
        }

        // "Sessions" was merged into "Security"
        if (string.Equals(Data.StartItem, "Sessions", StringComparison.OrdinalIgnoreCase))
        {
            Data.StartItem = "Security";
        }

        _categories = BuildCategories();

        // Add staff category if user is staff
        if (Data.User?.ValourStaff == true)
        {
            _categories.Add(new MainMenu.MenuCategory()
            {
                Name = Localizer["Staff"],
                Icon = "shield-fill",
                Items = new List<MainMenu.MenuItem>()
                {
                    new MainMenu.MenuItem()
                    {
                        Name = Localizer["Staff Tools"],
                        Icon = "tools",
                        Description = Localizer["Manage users and reports"],
                        Content = StaffToolsContent
                    }
                }
            });
        }
    }

    public class ModalParams
    {
        public User User;
        public string StartCategory;
        public string StartItem;
    }

    private async Task LogOut()
    {
        try
        {
            var cData = new ConfirmModalComponent.ModalParams(
            Localizer["Log Out"],
            Localizer["Are you sure?"],
            Localizer["Yes, log out"],
            Localizer["Cancel"],
            PerformLogoutAsync,
            () =>
            {
                return Task.CompletedTask;
            }
        );

            ModalRoot.OpenModal<ConfirmModalComponent>(cData);
        }
        catch (Exception e)
        {
            Console.WriteLine(e.Message);

            // If an error occurs in building/using the ConfirmModal, it reverts back to original behavior and logs out regardless
            await PerformLogoutAsync();
        }
    }

    private async Task PerformLogoutAsync()
    {
        // Revokes the token server-side and clears SDK auth state (best-effort)
        var result = await Client.AuthService.LogoutAsync();
        Console.WriteLine($"Logout result: {result.Message}");

        // Always clear the locally stored token so the next launch can't
        // auto-login with a revoked token and end up in a broken state
        try
        {
            await LocalStorage.RemoveAsync("token");
        }
        catch (Exception e)
        {
            Console.WriteLine($"Failed to clear stored token: {e.Message}");
        }

        NavManager.NavigateTo("/", true);
    }

    private async Task OpenStaffTools()
    {
        var data = new ModToolsWindowData()
        {
            Staff = true
        };

        var content = ModToolsWindowComponent.GetDefaultContent(data);
        var floatingProps = ModToolsWindowComponent.GetDefaultFloatingProps();
        await WindowService.TryAddFloatingWindow(content, floatingProps);

        Close();
    }

}
