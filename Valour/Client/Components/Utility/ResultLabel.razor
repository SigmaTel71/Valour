@inject IStringLocalizer<ValourApp> CommonLocalizer

<LanguageTrackProvider OnInitializeEvent="provider => provider.RegisterComponent(this)" />
@if (Result is null)
{
    return;
}

@if (Result.Success)
{
    <div class="result-message success">
        <p>
            <i class="bi bi-check-circle"></i> @(Localizer(Result.Message) ?? CommonLocalizer["Success!"])
        </p>
    </div>
}
else
{
    <div class="result-message error">
        <p>
            <span><i class="bi bi-exclamation-circle"></i> @(Localizer(Result.Message) ?? CommonLocalizer["An error occured."])</span>
            <a class="details" @onclick="@OnDetails">@CommonLocalizer["Details"]</a>
        </p>
    </div>
}

@code {
    
    [CascadingParameter]
    public ModalRoot ModalRoot { get; set; }
    
    [Parameter]
    public ITaskResult Result { get; set; }
    
    [Parameter]
    public string Style { get; set; }

    [Parameter]
    public IStringLocalizer<ComponentBase> ParentComponentLocalizer { get; set; } = null;

    private string Localizer(string key)
    {
        if (ParentComponentLocalizer is null)
            return key;

        return ParentComponentLocalizer.GetString(key);
    }

    
    private void OnDetails()
    {
        var data = new ErrorModal.ModalParams()
        {
            Result = Result
        };
        
        ModalRoot.OpenModal<ErrorModal>(data);
    }
}